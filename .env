# --- Postgres (DB) ---
POSTGRES_USER=admin
POSTGRES_PASSWORD=postgres123
POSTGRES_DB=privacy_docs
POSTGRES_URL=postgresql://admin:postgres123@postgres:5432/privacy_docs
DATABASE_URL=postgresql://admin:postgres123@postgres:5432/privacy_docs

# --- API / worker / runtime ---
API_PORT=3001
NODE_ENV=development

# JWT & query hashing (must be set)
JWT_SECRET=jwtsecret123
QUERY_HASH_SALT=hashsalt123

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- MinIO / S3 ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_BUCKET=privacy-documents
MINIO_ENDPOINT=minio
MINIO_PORT=9000

# --- ChromaDB (Vector DB) ---
CHROMA_HOST=chromadb
CHROMA_PORT=8000
CHROMADB_URL=http://chromadb:8000
CHROMADB_COLLECTION=privacy_documents

# --- Ollama Model endpoints ---
OLLAMA_URL=http://ollama:11434
OLLAMA_EMBED_MODEL=mxbai-embed-large
OLLAMA_MODEL=mistral

# --- Frontend (React) ---
REACT_APP_API_URL=http://localhost:3001
REACT_APP_MINIO_ENDPOINT=http://localhost:9000
REACT_APP_CHROMA_ENDPOINT=http://localhost:8000
REACT_APP_OLLAMA_ENDPOINT=http://localhost:11434

# --- Internal Worker URL (API -> worker) ---
WORKER_URL=http://worker:8001
WORKER_POSTGRES_URL=${POSTGRES_URL}

# --- CORS for dev ---
CORS_ORIGIN=http://localhost:3000

# --- Defaults ---
TOP_K=5
