# -----------------------------
# Postgres / Database
# -----------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres123
POSTGRES_DB=privacy_docs
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
# canonical DB URL used by services
DATABASE_URL=postgresql://postgres:postgres123@localhost:5432/privacy_docs
# (optional duplicate if some code expects POSTGRES_URL)
POSTGRES_URL=${DATABASE_URL}

# -----------------------------
# Redis
# -----------------------------
REDIS_URL=redis://localhost:6379/0

# -----------------------------
# MinIO (object storage)
# -----------------------------
MINIO_HOST=localhost
MINIO_PORT=9000
# Use full URL form for endpoints (needed by many HTTP clients)
MINIO_ENDPOINT=http://localhost:9000
MINIO_BUCKET=privacy-documents
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
# root/recovery credentials (same here)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
# Host-viewable minio URL for browser on host machine (useful for docs)
MINIO_HOST_URL=http://localhost:9000

# -----------------------------
# ChromaDB / Vector store
# -----------------------------
CHROMA_HOST=localhost
CHROMA_PORT=8000
# Add explicit variables expected by worker
CHROMADB_HOST=localhost
CHROMADB_PORT=8000
CHROMADB_URL=http://localhost:8000
CHROMADB_COLLECTION=privacy_documents

# -----------------------------
# Ollama / LLM
# -----------------------------
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=phi3:mini
OLLAMA_EMBED_MODEL=nomic-embed-text

# -----------------------------
# API & Worker
# -----------------------------
API_PORT=3001
WORKER_PORT=8001
WORKER_URL=http://localhost:8001
NODE_ENV=development

# Worker: embed metadata persistence path (volume mount)
EMBED_META_PATH=/tmp/embed_meta/embed_meta.json

# DB pool sizing for psycopg2 (worker will read these)
DB_MIN_CONN=1
DB_MAX_CONN=6

# -----------------------------
# Security / App secrets
# -----------------------------
# JWT Secrets (Cryptographically Secure - Generated 2025-12-09)
JWT_SECRET=7f3a8b9c2e1d4f6a8c9b2e3d4f5a6b7c8d9e0f1a2b3c4d5e6f7a8b9c0d1e2f3a4b5c6d7e8f9a0b1c2d3e4f5a6b7c8d9e0f1a2b3c4d5e6f7a8b9c0d1e2f3a
JWT_REFRESH_SECRET=3d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8a9b0c1d2e3f4a5b6c7d8e9f0a1b2c3d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8a9b0c1d2e3f4a5b6c7d8e9f0a1b2c
QUERY_HASH_SALT=hashsalt123

# Development-only helpers
DEV_AUTH_KEY=super-secret-dev-key
DEV_TOKEN_EXPIRES_IN=30d

# Frontend URL for CORS
FRONTEND_URL=http://localhost:3000

# -----------------------------
# Frontend (Vite environment variables)
# -----------------------------
# Vite requires VITE_* prefix — these are available in import.meta.env
VITE_API_URL=http://localhost:3001
VITE_MINIO_ENDPOINT=http://localhost:9000
VITE_CHROMA_ENDPOINT=http://localhost:8000
VITE_OLLAMA_ENDPOINT=http://localhost:11434

# Legacy CRA names (not used by Vite) — safe to keep if some scripts expect them
REACT_APP_API_URL=http://localhost:3001
REACT_APP_MINIO_ENDPOINT=http://localhost:9000
REACT_APP_CHROMA_ENDPOINT=http://localhost:8000
REACT_APP_OLLAMA_ENDPOINT=http://localhost:11434

# -----------------------------
# CORS
# -----------------------------
# comma-separated list of allowed origins (backend may parse CORS_ORIGINS)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173
CORS_ORIGIN=http://localhost:3000

# -----------------------------
# Other
# -----------------------------
TOP_K=5

# -----------------------------
# Phase 1: Hybrid RAG Config
# -----------------------------
OPENAI_API_KEY=
PRIMARY_MODEL=gpt-4o-mini
PRIMARY_EMBED=text-embedding-3-small

LOCAL_CHAT_MODEL=phi3:mini
LOCAL_EMBED_MODEL=nomic-embed-text

# -----------------------------
# ALE (Application-Level Encryption)
# -----------------------------
ALE_MASTER_KEY=2aa4fbe08383ca44dd57365711ef438430930c74855e3e4ac5b3829114bca9da
