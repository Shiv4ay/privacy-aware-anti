# Database
POSTGRES_USER=admin
POSTGRES_PASSWORD=postgres123
POSTGRES_DB=privacy_docs

# API (Backend)
API_PORT=3001
NODE_ENV=development
DATABASE_URL=postgresql://admin:postgres123@postgres:5432/privacy_docs

# REDIS
REDIS_URL=redis://redis:6379/0.

# MinIO/S3
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_BUCKET=privacy-documents
MINIO_ENDPOINT=minio
MINIO_PORT=9000

# ChromaDB (Vector DB)
CHROMA_HOST=chromadb
CHROMA_PORT=8000

# Ollama/LLM
OLLAMA_HOST=ollama
OLLAMA_PORT=11434

# Frontend (React) - only works with REACT_APP_ prefix
REACT_APP_API_URL=http://localhost:3001
REACT_APP_MINIO_ENDPOINT=http://localhost:9000
REACT_APP_CHROMA_ENDPOINT=http://localhost:8000
REACT_APP_OLLAMA_ENDPOINT=http://localhost:11434

# Worker (if needed)
WORKER_API_URL=http://api:3001

# If configuring CORS for local dev:
CORS_ORIGIN=http://localhost:3000
